# gofr-agent services manifest
# ─────────────────────────────────────────────────────────────────────────────
# Each entry under `services:` declares one downstream MCP service.
# At startup gofr-agent will connect to every enabled service, discover its
# tools and surface them through its own reasoning agent.
#
# Fields
# ──────
# name        (required) — identifier used in tool names, e.g. "rag" → tools
#               become "rag__search", "rag__ingest", …
# url         (required) — Streamable-HTTP MCP endpoint reachable from the
#               gofr-agent container. Use Docker service names or routable DNS
#               names, never localhost/127.0.0.1 for service-to-service calls.
# token       (optional) — bearer token sent in Authorization header
# token_env   (optional) — name of env-var that holds the bearer token
#                          (takes precedence over `token`)
# hub_callback_token_env (optional) — env-var holding the service -> gofr-agent
#               callback token for `_store_result` / `_get_result` access
# description (optional) — shown in the agent's system prompt
# enabled     (optional, default: true) — set to false to skip the service
#
# ─────────────────────────────────────────────────────────────────────────────

services:

  # ── Example 1: hub-capable market data service ────────────────────────────
  - name: instruments
    url: http://gofr-instruments:8100/mcp
    description: >
      Instrument metadata and OHLCV history. This service can publish large
      bar sets to the gofr-agent results hub and return descriptors instead of
      inline payloads.
    token_env: INSTRUMENTS_MCP_TOKEN
    hub_callback_token_env: INSTRUMENTS_HUB_CALLBACK_TOKEN
    enabled: true

  # ── Example 2: code-execution sandbox ─────────────────────────────────────
  - name: sandbox
    url: http://gofr-sandbox:8200/mcp
    description: >
      Secure Python sandbox. Use this to run calculations, data transformations
      or to verify code snippets.
    token_env: SANDBOX_MCP_TOKEN
    enabled: true

  # ── Example 3: disabled / staging service ─────────────────────────────────
  - name: staging-search
    url: https://staging-search.internal.example/mcp
    description: Staging search service (currently disabled).
    enabled: false
